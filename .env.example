# Upload provider: oss | http
UPLOAD_PROVIDER=oss

# Aliyun OSS (required when UPLOAD_PROVIDER=oss)
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket
OSS_ACCESS_KEY_ID=your-ak
OSS_ACCESS_KEY_SECRET=your-sk

# Optional custom domain for final CDN URLs (e.g. https://cdn.example.com)
CDN_BASE_URL=

# Optional object prefix (default: figma-assets)
OSS_DEFAULT_PREFIX=figma-assets

# HTTP uploader (required when UPLOAD_PROVIDER=http)
HTTP_UPLOAD_URL=
HTTP_UPLOAD_FILE_FIELD=file

# For your response sample: data.filePath
HTTP_UPLOAD_RESPONSE_FILE_PATH_FIELD=data.filePath

# Optional success validation
HTTP_UPLOAD_RESPONSE_SUCCESS_FIELD=success
HTTP_UPLOAD_RESPONSE_SUCCESS_VALUE=true

# Optional JSON object strings
# Example: {"Referer":"https://your-domain.example/upload-page"}
HTTP_UPLOAD_HEADERS_JSON={}

# Example with your fixed fields (remove spaces/newlines in real env)
# HTTP_UPLOAD_FORM_JSON={"appName":"your-app","modelName":"your-model","userId":"your-user-id","autoConvert":"false","requestUrl":"https://your-domain.example/upload-page"}
HTTP_UPLOAD_FORM_JSON={}
